{
  "name": "SFTP Deploy (Template)",
  "host": "your-server-host.example.com",
  "protocol": "sftp",
  "port": 22,
  "username": "your-ssh-user",
  "privateKeyPath": "C:/Users/your-user/.ssh/id_rsa",
  "remotePath": "/var/www/html",
  "uploadOnSave": true,
  "ignore": [
    ".vscode",
    ".git",
    ".DS_Store",
    "node_modules"
  ]
}
