# Server
PORT=3000
JSON_BODY_LIMIT=20mb

# PostgreSQL (Azure Database for PostgreSQL - Flexible Server)
PGHOST=your-server-name.postgres.database.azure.com
PGPORT=5432
PGDATABASE=postgres
PGUSER=your_admin_user
PGPASSWORD=your_password
PGSSLMODE=require
PGSSL_REJECT_UNAUTHORIZED=false

# Optional API auth (recommended)
API_KEY=replace-with-a-long-random-string

# CORS: comma-separated whitelist. Leave empty to allow all origins (dev only).
CORS_ALLOWED_ORIGIN=http://127.0.0.1:5500,https://your-frontend-domain

# Auto-create table/index on startup (set false if you manage schema manually)
AUTO_INIT_SCHEMA=true
